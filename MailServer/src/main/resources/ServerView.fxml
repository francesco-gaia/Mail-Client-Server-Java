<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="550.0" prefWidth="750.0" style="-fx-background-color: #f4f6f7;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="server.controller.ServerController">

    <top>
        <VBox alignment="CENTER" spacing="8" style="-fx-background-color: #2c3e50; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 2);">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>
            <Label text="MAIL SERVER DASHBOARD" textFill="WHITE">
                <font>
                    <Font name="Segoe UI Bold" size="22.0" />
                </font>
            </Label>
            <Label fx:id="statusLabel" text="Stato: Offline" textFill="#bdc3c7">
                <font>
                    <Font name="Segoe UI" size="14.0" />
                </font>
            </Label>
        </VBox>
    </top>

    <center>
        <VBox spacing="5">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>

            <Label text="REGISTRO EVENTI (LOG)" textFill="#7f8c8d">
                <font>
                    <Font name="System Bold" size="12.0" />
                </font>
            </Label>

            <ListView fx:id="logListView" BorderPane.alignment="CENTER" VBox.vgrow="ALWAYS"
                      style="-fx-font-family: 'Consolas', 'Monospaced'; -fx-font-size: 13; -fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 3;" />
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="30" style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <Button fx:id="btnStart" onAction="#onStartClick" prefHeight="45.0" prefWidth="160.0"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 5, 0, 0, 1);"
                    text="AVVIA SERVER">
                <font>
                    <Font size="14.0" />
                </font>
            </Button>

            <Button fx:id="btnStop" disable="true" onAction="#onStopClick" prefHeight="45.0" prefWidth="160.0"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 5, 0, 0, 1);"
                    text="ARRESTA SERVER">
                <font>
                    <Font size="14.0" />
                </font>
            </Button>
        </HBox>
    </bottom>

</BorderPane>