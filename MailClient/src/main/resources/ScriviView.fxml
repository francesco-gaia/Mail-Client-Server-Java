<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" prefWidth="500.0" prefHeight="400.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="client.controller.ScriviController">

    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>

    <Label fx:id="titolo" text="Nuovo Messaggio">
        <font><Font name="System Bold" size="16.0" /></font>
    </Label>

    <GridPane hgap="10.0" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints minWidth="60.0" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="A:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="textRecipient" promptText="destinatario@mail.com" GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <Label text="Oggetto:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextField fx:id="textSubject" GridPane.rowIndex="1" GridPane.columnIndex="1" />
    </GridPane>

    <Label fx:id="errorLabel" textFill="RED" visible="false" />

    <Label text="Testo:" />
    <TextArea fx:id="textMessage" wrapText="true" VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Invia" onAction="#handleSend" defaultButton="true" style="-fx-background-color: #b01525; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;"/>
    </HBox>

</VBox>
